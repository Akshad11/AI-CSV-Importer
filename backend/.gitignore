# =====================================================
# Dependencies
# =====================================================
node_modules/

# =====================================================
# Build Output
# =====================================================
dist/
build/
out/
coverage/

# =====================================================
# Environment Files
# =====================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Keep example environment
!.env.example

# =====================================================
# Logs
# =====================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =====================================================
# Runtime Data
# =====================================================
pids/
*.pid
*.pid.lock

# =====================================================
# Temporary Files
# =====================================================
tmp/
temp/
.tmp/
.cache/

# =====================================================
# Uploads
# Ignore uploaded files but keep the folder
# =====================================================
uploads/*
!uploads/.gitkeep

# =====================================================
# Test Output
# =====================================================
coverage/
.nyc_output/
vitest-report/
playwright-report/

# =====================================================
# Docker
# =====================================================
docker-compose.override.yml

# =====================================================
# IDE - VS Code
# =====================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# =====================================================
# JetBrains IDEs
# =====================================================
.idea/

# =====================================================
# Operating System Files
# =====================================================
.DS_Store
Thumbs.db
Desktop.ini

# =====================================================
# TypeScript
# =====================================================
*.tsbuildinfo

# =====================================================
# ESLint Cache
# =====================================================
.eslintcache

# =====================================================
# Prettier Cache
# =====================================================
.prettier-cache

# =====================================================
# Package Managers
# =====================================================
.pnpm-store/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# =====================================================
# npm Cache
# =====================================================
.npm/

# =====================================================
# Turbo / Nx
# =====================================================
.turbo/
nx-cache/

# =====================================================
# Local Databases
# =====================================================
*.sqlite
*.sqlite3
*.db

# =====================================================
# Certificates / Secrets
# =====================================================
*.pem
*.key
*.crt
*.pfx

# =====================================================
# Miscellaneous
# =====================================================
*.seed
*.tgz
