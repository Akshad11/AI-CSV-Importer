# ============================================================
# Frontend Environment Variables — Example Template
# ============================================================
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored automatically by Next.js.
# ============================================================

# Backend API base URL
# Points to the running Express backend gateway.
# Change this to your production URL when deploying.
# Example (local):      http://localhost:5000/api/v1/importer
# Example (production): https://api.yourapp.com/api/v1/importer
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1/importer
